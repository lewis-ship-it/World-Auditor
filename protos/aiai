#VRML_SIM R2023b utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/vehicles/protos/abstract/VehicleWheel.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/vehicles/protos/abstract/AckermannVehicle.proto"

PROTO AdvancedAISUV [
  field SFVec3f    translation 0 0.5 0
  field SFRotation rotation    0 1 0 0
  field SFString   name "AI_SUV"
]
{
  AckermannVehicle {
    translation IS translation
    rotation IS rotation
    name IS name
    controller "vehicle_controller"
    
    # --- VEHICLE GEOMETRY ---
    wheelbase 3.4
    trackFront 2.0
    trackRear 2.0

    # --- SUSPENSION SETTINGS ---
    # High front stiffness stops sinking; lower rear stiffness stops floating.
    suspensionFrontSpringConstant 400000
    suspensionFrontDampingConstant 10000
    suspensionRearSpringConstant 150000
    suspensionRearDampingConstant 8000

    # --- PHYSICAL PROPERTIES ---
    boundingObject Transform {
      translation 0.5 0 0.55
      children [
        Box {
          size 4.5 1.8 1.0
        }
      ]
    }
    physics Physics {
      # mass is 1800; density removed to fix the warning conflict
      mass 1800 
      centerOfMass [ 1.6 0 0.1 ] 
    }

    extensionSlot [
      # MAIN BODY VISUALS
      Transform {
        translation 0 0.5 0
        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0.1 0.1 0.12
              metalness 0.7
              roughness 0.3
            }
            geometry Box {
              size 4.5 1.0 2.0
            }
          }
        ]
      }

      # SENSORS
      Camera {
        name "front_camera"
        width 1280
        height 720
        translation 2.2 0.8 0
      }
      Lidar {
        name "lidar"
        translation 0 1.2 0
        horizontalResolution 720
        numberOfLayers 16
      }
      GPS {
        name "gps"
      }
      InertialUnit {
        name "imu"
      }

      # --- FRONT LEFT WHEEL ---
      HingeJoint {
        jointParameters HingeJointParameters {
          axis 0 1 0
          anchor 1.7 0.5 1.0
        }
        device [
          RotationalMotor {
            name "steer_fl"
          }
        ]
        endPoint VehicleWheel {
          name "wheel_fl"
          wheelRadius 0.5
          thickness 0.4
          physics Physics {
            mass 20
          }
        }
      }

      # --- FRONT RIGHT WHEEL ---
      HingeJoint {
        jointParameters HingeJointParameters {
          axis 0 1 0
          anchor 1.7 0.5 -1.0
        }
        device [
          RotationalMotor {
            name "steer_fr"
          }
        ]
        endPoint VehicleWheel {
          name "wheel_fr"
          wheelRadius 0.5
          thickness 0.4
          physics Physics {
            mass 20
          }
        }
      }

      # --- REAR LEFT WHEEL ---
      HingeJoint {
        jointParameters HingeJointParameters {
          axis 0 0 1
          anchor -1.7 0.5 1.0
        }
        device [
          RotationalMotor {
            # unique name for driving motor
            name "wheel_rl"
          }
        ]
        endPoint VehicleWheel {
          name "wheel_rl_solid"
          wheelRadius 0.5
          thickness 0.4
          physics Physics {
            mass 20
          }
        }
      }

      # --- REAR RIGHT WHEEL ---
      HingeJoint {
        jointParameters HingeJointParameters {
          axis 0 0 1
          anchor -1.7 0.5 -1.0
        }
        device [
          RotationalMotor {
            # unique name for driving motor
            name "wheel_rr"
          }
        ]
        endPoint VehicleWheel {
          name "wheel_rr_solid"
          wheelRadius 0.5
          thickness 0.4
          physics Physics {
            mass 20
          }
        }
      }
    ]
  }
}